{
  "name": "visitors-log-app",
  "version": "1.0.0",
  "description": "An Electron app for managing visitor logs.",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dist:win": "electron-builder --win --x64",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder -w -m"
  },
  "keywords": [],
  "author": "Jamal Laqdiem <jamal@example.com>",
  "license": "ISC",
  "dependencies": {
    "csv-parse": "^5.5.5"
  },
  "devDependencies": {
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.jamallaqdiem.visitorslog",
    "productName": "Banned Visitors App",
    "nodeGypRebuild": false,
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "extraResources": [
        "photos/**",
        "visitors.csv"
      ],
      "category": "Utility"
    },
    "directories": {
      "output": "dist"
    },
    "files": [
      "logo.svg",
      "main.js",
      "preload.js",
      "index.html",
      "script.js",
      "style.css"
    ]
  }
}
